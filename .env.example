
### Copy this file to `.env` or `.env.local` and fill in your values

# MongoDB connection (local or Atlas)
# Local example: mongodb://localhost:27017/cricket_quiz
# Atlas example: mongodb+srv://<username>:<password>@cluster0.vrcytvs.mongodb.net/<dbname>
MONGODB_URI=mongodb://localhost:27017/cricket_quiz

# URL where the backend API is reachable (frontend will call this)
VITE_API_URL=http://localhost:4000/api

# JWT secret used by the backend for signing tokens (development only)
JWT_SECRET=change_this_jwt_secret_for_production

# Optional: override Vite dev server port
# VITE_PORT=5173
